<UserControl x:Class="SQLdata_Generator.Views.DeveloperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="开发者模式" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1"
                    Background="#FAFAFA" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="数据库列表" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="↻" Command="{Binding RefreshDatabasesCommand}"
                                Width="26" Height="22" FontSize="12" ToolTip="刷新"/>
                    </Grid>

                    <ListBox Grid.Row="1" ItemsSource="{Binding AllDatabases}"
                             SelectedItem="{Binding SelectedDatabase}"
                             Margin="0,0,0,3" MinHeight="100"/>

                    <TextBlock Grid.Row="2" Text="数据表列表" FontWeight="Bold" Margin="0,6,0,3"/>

                    <ListBox Grid.Row="3" ItemsSource="{Binding AllTables}"
                             SelectedItem="{Binding SelectedTable}"
                             DisplayMemberPath="TableName"
                             Margin="0,0,0,3" MinHeight="80"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- Table Info -->
                <GroupBox Grid.Row="0" Header="表信息" Padding="5" Margin="0,0,0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <Button Command="{Binding ShowStructureCommand}" Width="80" Height="24">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsShowingStructure}" Value="True">
                                                <Setter Property="Background" Value="#0078D4"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe87d;" FontFamily="/Assets/Fonts/#iconfont"
                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="表结构" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowDataCommand}" Width="80" Height="24" Margin="3,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsShowingData}" Value="True">
                                                <Setter Property="Background" Value="#0078D4"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe64c;" FontFamily="/Assets/Fonts/#iconfont"
                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="表数据" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ColumnInfos}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  IsReadOnly="True" MaxHeight="160"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsShowingStructure, Converter={StaticResource BoolToVisConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName}" Width="120"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="150"/>
                                <DataGridTextColumn Header="可空" Binding="{Binding IsNullable}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding TableData}"
                                  AutoGenerateColumns="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  IsReadOnly="True" MaxHeight="160"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsShowingData, Converter={StaticResource BoolToVisConverter}}"/>
                    </Grid>
                </GroupBox>

                <!-- SQL Editor -->
                <GroupBox Grid.Row="1" Header="SQL编辑器" Padding="5" Margin="0,0,0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Text="{Binding SqlText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="13"
                                 TextWrapping="NoWrap" Margin="0,0,0,5"
                                 SpellCheck.IsEnabled="False"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding SaveResultsCommand}"
                                    Width="80" Height="26" Margin="0,0,5,0">
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe605;" FontFamily="/Assets/Fonts/#iconfont"
                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="保存结果" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExecuteSqlCommand}"
                                    Width="80" Height="26"
                                    Background="#0078D4" Foreground="White" FontWeight="Bold">
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe6e3;" FontFamily="/Assets/Fonts/#iconfont"
                                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="执行" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Results -->
                <GroupBox Grid.Row="2" Header="执行结果" Padding="5">
                    <Grid>
                        <DataGrid ItemsSource="{Binding QueryResults}"
                                  AutoGenerateColumns="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  IsReadOnly="True"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasQueryResults, Converter={StaticResource BoolToVisConverter}}"/>

                        <TextBox Text="{Binding QueryMessage}"
                                 Visibility="{Binding HasQueryMessage, Converter={StaticResource BoolToVisConverter}}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="13"
                                 BorderThickness="0" Background="Transparent"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#F5F5F5" Padding="5,3" Margin="0,5,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
