<UserControl x:Class="SQLdata_Generator.Views.DataImporterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Table Selection -->
        <GroupBox Header="选择目标数据表" Grid.Row="0" Margin="0,0,0,5" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                          ItemsSource="{Binding ConnectionService.DatabaseList}"
                          SelectedItem="{Binding SelectedDatabase}"
                          IsEditable="True"
                          Margin="3" VerticalAlignment="Center"
                          ToolTip="选择数据库"
                          IsEnabled="{Binding ConnectionService.IsServerConnected}"/>
                <ComboBox Grid.Row="1" Grid.Column="0"
                          ItemsSource="{Binding Tables}"
                          SelectedItem="{Binding SelectedTable}"
                          DisplayMemberPath="TableName"
                          Margin="3" VerticalAlignment="Center"
                          IsEnabled="{Binding IsDatabaseSelected}"/>
                <Button Grid.Row="1" Grid.Column="1" Command="{Binding LoadSchemaCommand}"
                        Margin="3" Width="100" Height="26">
                    <StackPanel Orientation="Horizontal" Margin="3,0">
                        <TextBlock Text="&#xe629;" FontFamily="/Assets/Fonts/#iconfont"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="加载表结构" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </GroupBox>

        <!-- Row 1: Column Mapping -->
        <GroupBox Header="字段映射" Grid.Row="1" Margin="0,0,0,5" Padding="5"
                  Visibility="{Binding IsSchemaLoaded, Converter={StaticResource BoolToVisConverter}}">
            <DataGrid ItemsSource="{Binding ColumnMappings}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" RowHeaderWidth="0"
                      IsReadOnly="True" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName}" Width="120"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="80"/>
                    <DataGridTextColumn Header="可空" Binding="{Binding IsNullable}" Width="60"/>
                    <DataGridTemplateColumn Header="Excel匹配" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MatchStatus}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMatched}" Value="False">
                                                    <Setter Property="Foreground" Value="#CC6600"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Row 2: Excel Selection -->
        <GroupBox Header="导入Excel文件" Grid.Row="2" Margin="0,0,0,5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ExcelFilePath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="3" VerticalAlignment="Center" IsReadOnly="True"
                         ToolTip="选择要导入的 .xlsx 文件"/>
                <Button Grid.Column="1" Command="{Binding BrowseExcelCommand}"
                        Margin="3" Width="80" Height="26">
                    <StackPanel Orientation="Horizontal" Margin="3,0">
                        <TextBlock Text="&#xe724;" FontFamily="/Assets/Fonts/#iconfont"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBlock Text="选择文件" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                    <Button Grid.Column="2" Command="{Binding ReadExcelCommand}"
                        Margin="3" Width="80" Height="26">
                        <StackPanel Orientation="Horizontal" Margin="3,0">
                            <TextBlock Text="&#xe61c;" FontFamily="/Assets/Fonts/#iconfont"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="读取预览" VerticalAlignment="Center"/>
                        </StackPanel>
                </Button>
            </Grid>
        </GroupBox>

        <!-- Row 3: Data Preview -->
        <GroupBox Header="数据预览" Grid.Row="3" Margin="0,0,0,5" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding PreviewInfo}" Margin="3,0,0,3"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewData}"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </GroupBox>

        <!-- Row 4: Insert Progress -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             Width="200" Height="18" Margin="3"/>
                <TextBlock Text="{Binding ProgressText}" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding SaveToDatabaseCommand}"
                    Margin="3" Width="110" Height="28">
                <StackPanel Orientation="Horizontal" Margin="3,0">
                    <TextBlock Text="&#xe60e;" FontFamily="/Assets/Fonts/#iconfont"
                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBlock Text="插入到数据库" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
