<UserControl x:Class="SQLdata_Generator.Views.DatabaseManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:SQLdata_Generator.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock Grid.Row="0" Text="数据库管理" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

        <!-- Row 1: Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1"
                    Background="#FAFAFA" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- Database Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="数据库列表" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="↻" Command="{Binding RefreshDatabasesCommand}"
                                Width="26" Height="22" FontSize="12" ToolTip="刷新"/>
                    </Grid>

                    <!-- Database List -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding AllDatabases}"
                             SelectedItem="{Binding SelectedDatabase}"
                             Margin="0,0,0,3" MinHeight="100"/>

                    <!-- Create Database -->
                    <Grid Grid.Row="2" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewDatabaseName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+库" Command="{Binding CreateDatabaseCommand}"
                                Width="36" Height="22" FontSize="12" ToolTip="新建数据库"/>
                    </Grid>

                    <!-- Drop Database -->
                    <Button Grid.Row="3" Command="{Binding DropDatabaseCommand}"
                            Height="26" Margin="0,3" FontSize="12">
                        <StackPanel Orientation="Horizontal" Margin="3,0">
                            <TextBlock Text="&#xe69b;" FontFamily="/Assets/Fonts/#iconfont"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="删除选中库" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Table Header -->
                    <TextBlock Grid.Row="4" Text="数据表列表" FontWeight="Bold" Margin="0,6,0,3"/>

                    <!-- Table List -->
                    <ListBox Grid.Row="5" ItemsSource="{Binding AllTables}"
                             SelectedItem="{Binding SelectedTable}"
                             DisplayMemberPath="TableName"
                             Margin="0,0,0,3" MinHeight="80"/>

                    <!-- Drop Table -->
                    <Button Grid.Row="6" Command="{Binding DropTableCommand}"
                            Height="26" Margin="0,3" FontSize="12" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Margin="3,0">
                            <TextBlock Text="&#xe6c3;" FontFamily="/Assets/Fonts/#iconfont"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="删除选中表" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Right Panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Table Structure -->
                    <GroupBox Header="现有表结构" Padding="5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DataGrid Grid.Row="0" ItemsSource="{Binding ColumnInfos}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" RowHeaderWidth="0"
                                      IsReadOnly="True" MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName}" Width="120"/>
                                    <DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="150"/>
                                    <DataGridTextColumn Header="可空" Binding="{Binding IsNullable}" Width="60"/>
                                    <DataGridTemplateColumn Header="操作" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" Width="40" Height="22"
                                                        Command="{Binding DataContext.DropColumnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding ColumnName}"
                                                        FontSize="12"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <!-- Add Column -->
                    <GroupBox Header="对当前表添加单个字段" Padding="5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="列名" FontSize="11"
                                       Foreground="#888" Margin="3,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="类型" FontSize="11"
                                       Foreground="#888" Margin="3,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="长度" FontSize="11"
                                       Foreground="#888" Margin="3,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="精度" FontSize="11"
                                       Foreground="#888" Margin="3,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="小数位" FontSize="11"
                                       Foreground="#888" Margin="3,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="可空" FontSize="11"
                                       Foreground="#888" Margin="6,2,3,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="自增" FontSize="11"
                                       Foreground="#888" Margin="6,2,3,1"/>

                            <TextBox Grid.Row="1" Grid.Column="0"
                                     Text="{Binding NewColumnName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="2" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{x:Static vm:DatabaseManageViewModel.CommonColumnTypes}"
                                      SelectedItem="{Binding NewColumnType}"
                                      IsEditable="True" Margin="2" VerticalAlignment="Center"/>
                            <Grid Grid.Row="1" Grid.Column="2">
                                <TextBox Text="{Binding NewColumnLength, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsLengthEnabled}"
                                         Margin="2" VerticalAlignment="Center"
                                         ToolTip="varchar(50)→填50"/>
                                <TextBlock Text="—" IsHitTestVisible="False"
                                           Foreground="#AAAAAA" VerticalAlignment="Center"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLengthEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Grid Grid.Row="1" Grid.Column="3">
                                <TextBox Text="{Binding NewColumnPrecision, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsPrecisionEnabled}"
                                         Margin="2" VerticalAlignment="Center"
                                         ToolTip="decimal(18,3)→填18"/>
                                <TextBlock Text="—" IsHitTestVisible="False"
                                           Foreground="#AAAAAA" VerticalAlignment="Center"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPrecisionEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Grid Grid.Row="1" Grid.Column="4">
                                <TextBox Text="{Binding NewColumnScale, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsScaleEnabled}"
                                         Margin="2" VerticalAlignment="Center"
                                         ToolTip="decimal(18,3)→填3"/>
                                <TextBlock Text="—" IsHitTestVisible="False"
                                           Foreground="#AAAAAA" VerticalAlignment="Center"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScaleEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <CheckBox Grid.Row="1" Grid.Column="5"
                                      IsChecked="{Binding NewColumnNullable}"
                                      VerticalAlignment="Center" Margin="5,0"/>
                            <CheckBox Grid.Row="1" Grid.Column="6"
                                      IsChecked="{Binding NewColumnIsIdentity}"
                                      IsEnabled="{Binding IsIdentityEnabled}"
                                      VerticalAlignment="Center" Margin="5,0"
                                      ToolTip="仅数值类型可用"/>
                            <Button Grid.Row="1" Grid.Column="7"
                                    HorizontalAlignment="Left"
                                    Command="{Binding AddColumnCommand}"
                                    Height="26" Margin="5,0" FontSize="12">
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe77b;" FontFamily="/Assets/Fonts/#iconfont"
                                               FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="添加字段" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </GroupBox>

                    <!-- Create Table -->
                    <GroupBox Header="新建表" Padding="5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="表名:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Grid.Column="1" Text="{Binding NewTableName, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding NewColumns}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="True"
                                      HeadersVisibility="Column" RowHeaderWidth="0"
                                       MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                      Margin="0,0,0,5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    <DataGridTemplateColumn Header="类型" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{x:Static vm:DatabaseManageViewModel.CommonColumnTypes}"
                                                          SelectedItem="{Binding ColumnType, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True" Width="110" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="长度" Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    <DataGridTextColumn Header="精度" Binding="{Binding Precision, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    <DataGridTextColumn Header="小数位" Binding="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    <DataGridCheckBoxColumn Header="可空" Binding="{Binding IsNullable, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                    <DataGridCheckBoxColumn Header="自增" Binding="{Binding IsIdentity, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Row="2" Margin="0,3,0,0">
                                <Button Content="+添加列定义" Command="{Binding AddNewColumnDefCommand}"
                                        Height="26" Width="90" HorizontalAlignment="Left"/>
                            </Grid>

                            <Separator Grid.Row="3" Margin="0,8,0,4"/>

                            <Grid Grid.Row="4" Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                    <Button  Command="{Binding DownloadTemplateCommand}"
                                            Height="26" Width="80" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal" Margin="3,0">
                                            <TextBlock Text="&#xe614;" FontFamily="/Assets/Fonts/#iconfont"
                                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="下载模板" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding BulkImportFromExcelCommand}"
                                            Height="26" Width="120">
                                        <StackPanel Orientation="Horizontal" Margin="3,0">
                                            <TextBlock Text="&#xe60b;" FontFamily="/Assets/Fonts/#iconfont"
                                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="选择Excel并导入" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding BulkImportResult}"
                                           Foreground="#555" FontSize="12"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasBulkImportResult, Converter={StaticResource BoolToVisConverter}}"/>
                            </Grid>

                            <Button Grid.Row="5" Command="{Binding CreateTableCommand}"
                                    Height="26" Width="80" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Margin="3,0">
                                    <TextBlock Text="&#xe83f;" FontFamily="/Assets/Fonts/#iconfont"
                                               FontSize="16" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="创建表" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Row 2: Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="5,3" Margin="0,5,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
