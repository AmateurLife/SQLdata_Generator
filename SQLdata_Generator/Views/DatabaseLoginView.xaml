<UserControl x:Class="SQLdata_Generator.Views.DatabaseLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:helper="clr-namespace:SQLdata_Generator.Helpers"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Background="#F8F8F8" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="数据库连接" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,15,0"/>

            <ComboBox Grid.Column="1" ItemsSource="{Binding AuthTypes}"
                      SelectedItem="{Binding AuthType}"
                      VerticalAlignment="Center" Margin="3"/>

            <TextBox Grid.Column="2" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Margin="3"
                     ToolTip="服务器地址"/>

            <TextBox Grid.Column="3" Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Margin="3"
                     ToolTip="用户名"
                     Visibility="{Binding IsSqlAuth, Converter={StaticResource BoolToVisConverter}}"/>

            <PasswordBox Grid.Column="4"
                         helper:PasswordBoxHelper.Attach="True"
                         helper:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" VerticalAlignment="Center" Margin="3"
                         Visibility="{Binding IsSqlAuth, Converter={StaticResource BoolToVisConverter}}"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                <Button Content="连接服务器" Command="{Binding ServerConnectCommand}"
                        Width="80" Height="26" Margin="3,0"/>
                <TextBlock Text="{Binding ConnectionStatus}"
                           VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold"
                           TextWrapping="Wrap" MaxWidth="500"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
