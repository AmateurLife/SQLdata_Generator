<Window x:Class="SQLdata_Generator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="700" Width="950" MinHeight="500" MinWidth="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Database Connection -->
        <GroupBox Header="数据库连接" Grid.Row="0" Margin="0,0,0,5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                         Margin="3" VerticalAlignment="Center"
                         ToolTip="输入SQL Server连接字符串，例如: Server=.;Database=TestDB;Trusted_Connection=True;TrustServerCertificate=True"/>
                <Button Grid.Column="1" Content="测试连接" Command="{Binding TestConnectionCommand}"
                        Margin="3" Width="80" Height="26"/>
                <TextBlock Grid.Column="2" Text="{Binding ConnectionStatus}"
                           Margin="10,3" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <!-- Row 1: Table Selection -->
        <GroupBox Header="选择数据表" Grid.Row="1" Margin="0,0,0,5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="3" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="加载表结构" Command="{Binding LoadSchemaCommand}"
                        Margin="3" Width="100" Height="26"/>
            </Grid>
        </GroupBox>

        <!-- Row 2: Column Configuration -->
        <GroupBox Header="字段配置" Grid.Row="2" Margin="0,0,0,5" Padding="5">
            <DataGrid ItemsSource="{Binding ColumnConfigs}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" RowHeaderWidth="0"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="2"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="字段名" Binding="{Binding ColumnName}"
                                        IsReadOnly="True" Width="120"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding DataType}"
                                        IsReadOnly="True" Width="80"/>
                    <DataGridTemplateColumn Header="生成模式" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableModes}"
                                          SelectedItem="{Binding SelectedMode, UpdateSourceTrigger=PropertyChanged}"
                                          Width="90" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="最小值" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsNumericMode}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="最大值" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsNumericMode}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="固定值" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding FixedValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsFixedMode}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="数据集(逗号分隔)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox Text="{Binding DatasetValues, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsDatasetMode}"/>
                                    <TextBlock IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Setter Property="Foreground" Value="#888"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="4,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAutoBackwardMode}" Value="True">
                                                        <Setter Property="Text" Value="自动从当前时间向前倒推"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Row 3: Generation Controls -->
        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="生成数量:" VerticalAlignment="Center" Margin="5,0"/>
            <TextBox Grid.Column="1" Text="{Binding RecordCount, UpdateSourceTrigger=PropertyChanged}"
                     Margin="3" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="生成预览" Command="{Binding GeneratePreviewCommand}"
                    Margin="5,0" Width="80" Height="26"/>
        </Grid>

        <!-- Row 4: Data Preview -->
        <GroupBox Header="数据预览" Grid.Row="4" Margin="0,0,0,5" Padding="5">
            <DataGrid ItemsSource="{Binding PreviewData}" AutoGenerateColumns="True"
                      IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>

        <!-- Row 5: Save Progress -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             Width="200" Height="18" Margin="3"/>
                <TextBlock Text="{Binding ProgressText}" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="保存到数据库" Command="{Binding SaveToDatabaseCommand}"
                    Margin="3" Width="110" Height="28"/>
        </Grid>
    </Grid>
</Window>
