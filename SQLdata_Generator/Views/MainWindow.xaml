<Window x:Class="SQLdata_Generator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="800" Width="1050" MinHeight="550" MinWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" prism:RegionManager.RegionName="LoginRegion"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
                <StackPanel Margin="5">
                    <TextBlock Text="SQL数据工具" FontWeight="Bold" FontSize="13"
                               Margin="5,10,5,15" HorizontalAlignment="Center"/>
                    <Button Content="数据生成" Command="{Binding NavigateGeneratorCommand}"
                            Height="36" Margin="5,3"
                            IsEnabled="{Binding IsNotOnGeneratorView}"/>
                    <Button Content="数据导入" Command="{Binding NavigateImporterCommand}"
                            Height="36" Margin="5,3"
                            IsEnabled="{Binding IsNotOnImporterView}"/>
                </StackPanel>
            </Border>

            <ContentControl Grid.Column="1" prism:RegionManager.RegionName="ContentRegion"/>
        </Grid>
    </Grid>
</Window>
